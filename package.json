{
  "name": "addf",
  "version": "1.0.0",
  "description": "AutomatonDevDrive Framework — AIエージェント駆動開発フレームワーク",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "docs:sync": "node scripts/sync-docs.mjs",
    "docs:dev": "npm run docs:sync && vitepress dev .claude/addf/webManual",
    "docs:build": "npm run docs:sync && vitepress build .claude/addf/webManual",
    "docs:preview": "vitepress preview .claude/addf/webManual",
    "dashboard:sync": "python3 .claude/addf/addfTools/generate-dashboard.py",
    "dashboard:dev": "npm run dashboard:sync && vitepress dev .claude/addf/dashboard",
    "dashboard:build": "npm run dashboard:sync && vitepress build .claude/addf/dashboard"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fruitriin/ADDF.git"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
